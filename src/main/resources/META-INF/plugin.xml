<idea-plugin require-restart="false" url="https://github.com/krotname/IdeaMarkdownTableEditor">
	<id>name.krot.markdown-table-editor-idea</id>
	<name>Markdown Table Editor</name>
	<vendor email="krotname@users.noreply.github.com" url="https://github.com/krotname">krotname</vendor>
	<version>@PLUGIN_VERSION@</version>
	<resource-bundle>messages.MarkdownTableEditorBundle</resource-bundle>
	<idea-version since-build="223"/>

	<description><![CDATA[
		<p>Markdown Table Editor keeps Markdown pipe tables readable directly in JetBrains IDE editors.</p>
		<ul>
			<li>Align Markdown tables with Tab.</li>
			<li>Sort data rows by the current column.</li>
			<li>Convert CSV/TSV text to Markdown tables.</li>
			<li>Insert a new Markdown table by size.</li>
			<li>Edit rows and columns without leaving the file.</li>
			<li>Use localized action names, dialogs, and messages in popular IDE locales.</li>
		</ul>
		<p>Compatible with IntelliJ Platform 2022.3+ / build 223+ JetBrains IDEs, including IntelliJ IDEA, Android Studio, WebStorm, PyCharm, PhpStorm, GoLand, CLion, Rider, RubyMine, DataGrip, DataSpell, RustRover, and other platform-based IDEs.</p>
		<p>RU: Редактор Markdown-таблиц с вертикальными чертами. Совместим с IDE JetBrains на IntelliJ Platform 2022.3+ / build 223+: IntelliJ IDEA, Android Studio, WebStorm, PyCharm, PhpStorm, GoLand, CLion, Rider, RubyMine, DataGrip, DataSpell, RustRover и другими IDE на платформе. Нажмите Tab внутри таблицы, чтобы выровнять ее, или используйте команды из меню Tools.</p>
	]]></description>

	<change-notes><![CDATA[
		<ul>
			<li>Added localized action names, menu text, dialogs, and user messages for 20 popular locales.</li>
			<li>Improved large-table performance by reducing table parsing, display-width, and formatting overhead.</li>
			<li>Added release-blocking Java/C++ core performance benchmarks to CI.</li>
			<li>Preserved Java/C++ core parity for trimmed pipe rows, escaped pipes, Unicode/CJK width, CSV/TSV conversion, sorting, and row/column edits.</li>
			<li>Kept the non-conflicting Tab plus Ctrl+Alt+Shift shortcut scheme from 9.0.0.</li>
		</ul>
	]]></change-notes>

	<depends>com.intellij.modules.platform</depends>

	<extensions defaultExtensionNs="com.intellij">
		<editorActionHandler action="EditorTab" implementationClass="name.krot.markdowntableidea.MarkdownTableTabHandler" order="first"/>
	</extensions>

	<actions>
		<action id="MarkdownTableEditor.TabAlign" class="name.krot.markdowntableidea.MarkdownTableActions$TabAlign">
			<keyboard-shortcut keymap="$default" first-keystroke="TAB"/>
		</action>

		<group id="MarkdownTableEditor.Group" popup="true">
			<add-to-group group-id="ToolsMenu" anchor="last"/>
			<add-to-group group-id="EditorPopupMenu" anchor="last"/>
			<action id="MarkdownTableEditor.Align" class="name.krot.markdowntableidea.MarkdownTableActions$Align">
				<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift 1"/>
			</action>
			<action id="MarkdownTableEditor.NextCell" class="name.krot.markdowntableidea.MarkdownTableActions$NextCell">
				<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift 2"/>
			</action>
			<action id="MarkdownTableEditor.PreviousCell" class="name.krot.markdowntableidea.MarkdownTableActions$PreviousCell">
				<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift 3"/>
			</action>
			<separator/>
			<action id="MarkdownTableEditor.SortAscending" class="name.krot.markdowntableidea.MarkdownTableActions$SortAscending">
				<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift EQUALS"/>
			</action>
			<action id="MarkdownTableEditor.SortDescending" class="name.krot.markdowntableidea.MarkdownTableActions$SortDescending">
				<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift MINUS"/>
			</action>
			<separator/>
			<action id="MarkdownTableEditor.ConvertCsvTsv" class="name.krot.markdowntableidea.MarkdownTableActions$ConvertCsvTsv">
				<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift 0"/>
			</action>
			<action id="MarkdownTableEditor.InsertTable" class="name.krot.markdowntableidea.MarkdownTableActions$InsertTable">
				<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift BACK_SLASH"/>
			</action>
			<separator/>
			<action id="MarkdownTableEditor.InsertRowBelow" class="name.krot.markdowntableidea.MarkdownTableActions$InsertRowBelow">
				<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift 4"/>
			</action>
			<action id="MarkdownTableEditor.DeleteRow" class="name.krot.markdowntableidea.MarkdownTableActions$DeleteRow">
				<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift 5"/>
			</action>
			<separator/>
			<action id="MarkdownTableEditor.InsertColumnRight" class="name.krot.markdowntableidea.MarkdownTableActions$InsertColumnRight">
				<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift 6"/>
			</action>
			<action id="MarkdownTableEditor.DeleteColumn" class="name.krot.markdowntableidea.MarkdownTableActions$DeleteColumn">
				<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift 7"/>
			</action>
			<separator/>
			<action id="MarkdownTableEditor.MoveRowUp" class="name.krot.markdowntableidea.MarkdownTableActions$MoveRowUp">
				<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift 8"/>
			</action>
			<action id="MarkdownTableEditor.MoveRowDown" class="name.krot.markdowntableidea.MarkdownTableActions$MoveRowDown">
				<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift 9"/>
			</action>
			<action id="MarkdownTableEditor.MoveColumnLeft" class="name.krot.markdowntableidea.MarkdownTableActions$MoveColumnLeft">
				<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift OPEN_BRACKET"/>
			</action>
			<action id="MarkdownTableEditor.MoveColumnRight" class="name.krot.markdowntableidea.MarkdownTableActions$MoveColumnRight">
				<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift CLOSE_BRACKET"/>
			</action>
		</group>
	</actions>
</idea-plugin>
